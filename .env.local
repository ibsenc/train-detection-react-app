# URL of your train detection backend
# In development, the Vite dev server proxies /api to this target,
# so you don't need CORS configured on the backend.
# In production builds, set VITE_API_BASE_URL to your backend URL
# (e.g. https://myserver.example.com) so API calls go to the right place.

VITE_API_BASE_URL=http://localhost:3000
